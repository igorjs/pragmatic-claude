# Allowlist strategy: ignore everything, then re-include custom content only.
# This keeps credentials, session history, caches, and server-pushed state
# out of git by default. Anything not explicitly un-ignored below stays out.

/*

# --- Custom content to track ---
!/.gitignore
!/README.md
!/LICENSE
!/Brewfile
!/install.sh
!/uninstall.sh
!/Makefile
!/prompts/
# settings.json is intentionally NOT tracked: it is the owner's live, personal
# config. The shipped install seed is the generated settings.shared.json below.
# Warning: `git clean -x` inside ~/.claude will delete the untracked settings.json.
!/settings.shared.json
!/permissions.shared.json
!/statusline.sh
!/commands/
!/skills/
!/agents/
!/hooks/
!/shell/
!/docs/
!/output-styles/
!/.github/
!/.claude-plugin/

# Override the global excludesfile (~/.gitignore.global), which ignores
# docs/superpowers/ (we want our specs tracked here).
# !/docs/superpowers/

# Build artifacts inside vendored/custom hook projects.
.venv/
.pytest_cache/
*.egg-info/

# plugins/ stays out of git: installed_plugins.json and known_marketplaces.json
# bake in machine-specific absolute paths, so the manifests aren't portable.
# (Default /* rule already ignores it; no allowlist entry.)

# --- Re-ignore generated/vendored content inside tracked dirs ---
# kept local-only, not shipped
/commands/sanitize-personal-commits.md
__pycache__/
*.pyc
*.pyo
.DS_Store
*.bak
*~
.claude/plans/
