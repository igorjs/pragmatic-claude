#!/usr/bin/env python3
"""git-push-guard: rewrite unpushed commit timestamps before pushing.

Usage: git-push-guard [--dry-run] [git push args...]
"""
from __future__ import annotations

import argparse
import hashlib
import subprocess
import sys
from datetime import datetime
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

from git_push_guard.git_ops import (  # noqa: E402
    NoUpstreamError,
    RewriteError,
    SigningNotConfiguredError,
    check_signing_configured,
    get_local_email,
    list_unpushed_commits,
    rewrite_dates,
)
from git_push_guard.lock import repo_lock  # noqa: E402
from git_push_guard.logger import log_rewrite  # noqa: E402
from git_push_guard.planner import plan_rewrites  # noqa: E402
from git_push_guard.windows import is_forbidden  # noqa: E402

LOG_FILE = Path.home() / ".claude" / "logs" / "git-push-guard.log"
LOCKS_DIR = Path.home() / ".claude" / "locks"


def repo_root() -> Path:
    r = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
    )
    if r.returncode != 0:
        print("git-push-guard: not in a git repo", file=sys.stderr)
        sys.exit(2)
    return Path(r.stdout.strip())


def lock_path_for(repo: Path) -> Path:
    h = hashlib.sha256(str(repo).encode()).hexdigest()[:16]
    return LOCKS_DIR / f"{h}.lock"


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--rewrite-only", action="store_true",
                        help="Rewrite timestamps but do not push (used by interceptor hook)")
    parser.add_argument("-h", "--help", action="store_true", dest="help_flag")
    args, push_args = parser.parse_known_args()

    if args.help_flag:
        print(__doc__)
        return 0

    repo = repo_root()
    try:
        with repo_lock(lock_path_for(repo)):
            return _run(repo, args.dry_run, args.rewrite_only, push_args)
    except BlockingIOError:
        print(
            "git-push-guard: another instance is running for this repo",
            file=sys.stderr,
        )
        return 3


def _do_push(repo: Path, push_args: list, dry_run: bool) -> int:
    if dry_run:
        print(f"git-push-guard: DRY RUN — would run: git push {' '.join(push_args)}")
        return 0
    r = subprocess.run(["git", "-C", str(repo), "push", *push_args])
    return r.returncode


def _run(repo: Path, dry_run: bool, rewrite_only: bool, push_args: list) -> int:
    local_email = get_local_email(repo)

    try:
        commits = list_unpushed_commits(repo, local_email=local_email)
    except NoUpstreamError:
        if rewrite_only:
            return 0  # nothing to sanitize
        print("git-push-guard: no upstream, pushing as-is", file=sys.stderr)
        return _do_push(repo, push_args, dry_run)

    if not commits:
        if rewrite_only:
            return 0
        return _do_push(repo, push_args, dry_run)

    forbidden = [
        c
        for c in commits
        if not c.is_merge
        and not c.is_foreign
        and is_forbidden(c.committer_date)
    ]
    if not forbidden:
        if rewrite_only:
            return 0
        return _do_push(repo, push_args, dry_run)

    try:
        check_signing_configured(repo)
    except SigningNotConfiguredError as e:
        if dry_run:
            print(
                f"git-push-guard: WARNING — signing not configured: {e} "
                "(would abort if not --dry-run)",
                file=sys.stderr,
            )
        else:
            print(
                f"git-push-guard: refusing to rewrite — signing not configured: {e}",
                file=sys.stderr,
            )
            return 4

    now = datetime.now().astimezone()
    try:
        rewrites = plan_rewrites(commits, now=now)
    except RuntimeError as e:
        print(f"git-push-guard: cannot plan rewrites: {e}", file=sys.stderr)
        return 5

    branch = (
        subprocess.run(
            ["git", "-C", str(repo), "branch", "--show-current"],
            capture_output=True,
            text=True,
        ).stdout.strip()
    )
    orig_by_sha = {c.sha: c for c in commits}
    for sha, new_dt in rewrites:
        c = orig_by_sha[sha]
        log_rewrite(
            LOG_FILE,
            repo=str(repo),
            branch=branch,
            commit=sha,
            original=c.committer_date,
            new=new_dt,
            reason="business-hours rewrite",
            min_gap_used=0,
        )

    if dry_run:
        print("git-push-guard: DRY RUN — planned rewrites:")
        for sha, new_dt in rewrites:
            c = orig_by_sha[sha]
            print(
                f"  {sha[:10]}  {c.committer_date.isoformat()}  ->  {new_dt.isoformat()}"
            )
        print(
            f"git-push-guard: DRY RUN — would then run: git push {' '.join(push_args)}"
        )
        return 0

    try:
        rewrite_dates(repo, rewrites, sign=True)
    except RewriteError as e:
        print(f"git-push-guard: rewrite failed: {e}", file=sys.stderr)
        return 6

    if rewrite_only:
        print(
            f"git-push-guard: rewrote {len(rewrites)} commit(s); push proceeds",
            file=sys.stderr,
        )
        return 0
    return _do_push(repo, push_args, dry_run)


if __name__ == "__main__":
    sys.exit(main())
